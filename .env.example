# Public browser-safe Supabase config
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server and Edge Function Supabase config
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# Claude
ANTHROPIC_API_KEY=

# Scout webhook and internal invocation secrets
SCOUT_WEBHOOK_SECRET=
AGENT_INTERNAL_SECRET=

# Public app URL used for report links and callbacks
PUBLIC_APP_URL=

# Optional companion automation
N8N_WEBHOOK_URL=
N8N_HMAC_SECRET=
SLACK_WEBHOOK_URL=
TEAMS_WEBHOOK_URL=

# Optional scrape and tracing integrations
FIRECRAWL_API_KEY=
LANGSMITH_API_KEY=
VERCEL_URL=

# Post-P17 expansion — all OPTIONAL and default-off (keep the $0 keyless core path).
# Firmographic enrichment (PROTOTYPE, Wave 3 #13): keyless CC0 sources, cited.
SCOUT_ENRICH_ENABLED=
# Descriptive User-Agent required by SEC EDGAR (bare fetch 403s) if EDGAR enrich is used.
SCOUT_EDGAR_USER_AGENT=
# Optional bounded external search (1k/mo free → non-$0 if used; flag it).
TAVILY_API_KEY=
# Optional async tracing (2nd vendor; the demo skips it — DB telemetry answers cost).
HELICONE_API_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
